# IronClaw configuration template. Copy to `.env` and fill in.
# Local-first, Rust-native: Fjall stores everything under ~/.ironclad/. No external DB.
#
# IMPORTANT: on Windows, use FORWARD slashes in paths. dotenvy parses escape
# sequences in both unquoted and double-quoted values, so `\U` / `\t` / `\n`
# blow up the file. Forward slashes work everywhere on Windows.
#     WHISPER_PATH=C:/tools/whisper/Release/whisper-server.exe     ✓
#     WHISPER_PATH=C:\tools\whisper\Release\whisper-server.exe     ✗ (breaks .env)

# Obsidian vault root (used by tooling outside IronClaw)
# VAULT_PATH=C:/Users/you/Documents/Vault

# ── LLM: Anthropic Claude API ─────────────────────────────────────────────
# Get your key at https://console.anthropic.com (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-...
# Model alias or dated ID. Examples:
#   claude-sonnet-4-6            (alias, auto-tracks latest Sonnet 4.6)
#   claude-sonnet-4-6-20251001   (pinned dated version)
#   claude-opus-4-5              (Opus 4.5)
#   claude-haiku-4-5             (Haiku 4.5)
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_DEFAULT_MAX_TOKENS=4096

# ── Embeddings (optional; OpenAI only) ────────────────────────────────────
EMBEDDING_ENABLED=false
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=sk-...

# ── Agent Settings ────────────────────────────────────────────────────────
AGENT_NAME=ironclad
AGENT_MAX_PARALLEL_JOBS=5
AGENT_JOB_TIMEOUT_SECS=3600
AGENT_STUCK_THRESHOLD_SECS=300
AGENT_USE_PLANNING=true

# Self-repair
SELF_REPAIR_CHECK_INTERVAL_SECS=60
SELF_REPAIR_MAX_ATTEMPTS=3

# Heartbeat (proactive periodic execution)
HEARTBEAT_ENABLED=false
HEARTBEAT_INTERVAL_SECS=1800
HEARTBEAT_NOTIFY_CHANNEL=cli
HEARTBEAT_NOTIFY_USER=default

# ── Safety ────────────────────────────────────────────────────────────────
SAFETY_MAX_OUTPUT_LENGTH=100000
SAFETY_INJECTION_CHECK_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────
RUST_LOG=ironclad=debug,tower_http=debug

# ── Channels (CLI/TUI always on; rest opt-in) ─────────────────────────────
# Slack
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_SIGNING_SECRET=...
#
# Telegram
# TELEGRAM_BOT_TOKEN=...
#
# HTTP webhook
# HTTP_HOST=0.0.0.0
# HTTP_PORT=8080
# HTTP_WEBHOOK_SECRET=...
#
# Public tunnel (ngrok / Cloudflare)
# TUNNEL_URL=https://your-tunnel.ngrok.io

# ── Gateway (set by `cargo run-jarvis`; documented here for reference) ────
# GATEWAY_ENABLED=true
# GATEWAY_HOST=127.0.0.1
# GATEWAY_PORT=3030

# ── Voice gateway (local, private) ────────────────────────────────────────
# STT: whisper-server daemon spawned by `cargo run-jarvis` on :8932.
# TTS: piper, shelled out per request.
# Paths MUST be quoted on Windows.
#
# Whisper.cpp builds: https://github.com/ggerganov/whisper.cpp
# WHISPER_PATH=C:/tools/whisper/Release/whisper-server.exe
# WHISPER_MODEL=C:/models/whisper/ggml-large-v3-turbo-q8_0.bin
# WHISPER_SERVER_URL=http://127.0.0.1:8932   # default; only set if remoting
#
# Piper builds: https://github.com/rhasspy/piper
# PIPER_PATH=C:/tools/piper/piper/piper.exe
# PIPER_VOICE=C:/models/piper/en_GB-alan-medium.onnx

# ── Secrets (encrypted credential store) ──────────────────────────────────
# Master key is stored in OS keychain by default (set during onboarding).
# Override here for CI/Docker:
# SECRETS_MASTER_KEY=<hex-encoded 32+ bytes>
